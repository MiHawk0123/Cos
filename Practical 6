.model small
.stack 100h
.code
main proc
 mov ax,13h
 int 10h ; Graphics mode
 mov ah,0Ch
 mov al,2 ; Green color
 mov bh,0
 mov cx,60
 mov dx,60
 mov si,80 ; Top
T: int 10h
 inc cx
 dec si
 jnz T
 mov si,40 ; Right
R: int 10h
 inc dx
 dec si
 jnz R
 mov si,80 ; Bottom
B: int 10h
 dec cx
 dec si
 jnz B
 mov si,40 ; Left
L: int 10h
 dec dx
 dec si
 jnz L
 mov ah,0
 int 16h ; Wait key
 mov ax,3
 int 10h ; Back to text
 mov ah,4Ch
 int 21h
main endp
end main
