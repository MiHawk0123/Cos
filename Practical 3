.MODEL SMALL
.STACK 100H
.DATA
    MSG1 DB 'Enter first digit: $'
    MSG2 DB 'Enter second digit: $'
    RESULT DB 'Result: $'
.CODE
MAIN:
    MOV AX, @DATA
    MOV DS, AX

    ; Input first digit
    LEA DX, MSG1
    MOV AH, 09H
    INT 21H

    MOV AH, 01H
    INT 21H
    SUB AL, 30H
    MOV BL, AL

    ; Input second digit
    LEA DX, MSG2
    MOV AH, 09H
    INT 21H

    MOV AH, 01H
    INT 21H
    SUB AL, 30H

    ADD AL, BL
    AAA              ; BCD adjust

    ADD AL, 30H      ; convert to ASCII

    ; Display result
    LEA DX, RESULT
    MOV AH, 09H
    INT 21H

    MOV DL, AL
    MOV AH, 02H
    INT 21H

    MOV AH, 4CH
    INT 21H
END MAIN
